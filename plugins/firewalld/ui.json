{
  "main": [
    {
      "type": "main",
      "title": "Firewalld Configuration",
      "description": "Choose a firewalld configuration area.",
      "configType": "firewalldMain",
      "items": [
        {
          "type": "section",
          "title": "Configuration Hub",
          "description": "",
          "items": [
            {
              "type": "pageButton",
              "title": "Main Configuration",
              "description": "Edit firewalld.conf settings.",
              "items": [
                {
                  "type": "section",
                  "title": "firewalld.conf",
                  "description": "",
                  "items": [
                    {
                      "type": "textShort",
                      "title": "Default zone",
                      "description": "",
                      "key": "DefaultZone",
                      "default": "public"
                    },
                    {
                      "type": "dropdown",
                      "title": "Firewall backend",
                      "description": "",
                      "key": "FirewallBackend",
                      "default": "nftables",
                      "options": [
                        "nftables",
                        "iptables"
                      ]
                    },
                    {
                      "type": "textShort",
                      "title": "Minimal mark",
                      "description": "",
                      "key": "MinimalMark",
                      "default": "100"
                    },
                    {
                      "type": "switch",
                      "title": "Cleanup on exit",
                      "description": "",
                      "key": "CleanupOnExit",
                      "default": "yes",
                      "trueValue": "yes",
                      "falseValue": "no"
                    },
                    {
                      "type": "switch",
                      "title": "Cleanup modules on exit",
                      "description": "",
                      "key": "CleanupModulesOnExit",
                      "default": "yes",
                      "trueValue": "yes",
                      "falseValue": "no"
                    },
                    {
                      "type": "switch",
                      "title": "Lockdown",
                      "description": "",
                      "key": "Lockdown",
                      "default": "no",
                      "trueValue": "yes",
                      "falseValue": "no"
                    },
                    {
                      "type": "switch",
                      "title": "IPv6 reverse path filter",
                      "description": "",
                      "key": "IPv6_rpfilter",
                      "default": "yes",
                      "trueValue": "yes",
                      "falseValue": "no"
                    },
                    {
                      "type": "switch",
                      "title": "Individual calls",
                      "description": "",
                      "key": "IndividualCalls",
                      "default": "no",
                      "trueValue": "yes",
                      "falseValue": "no"
                    },
                    {
                      "type": "switch",
                      "title": "Flush all on reload",
                      "description": "",
                      "key": "FlushAllOnReload",
                      "default": "yes",
                      "trueValue": "yes",
                      "falseValue": "no"
                    },
                    {
                      "type": "switch",
                      "title": "RFC3964 IPv4",
                      "description": "",
                      "key": "RFC3964_IPv4",
                      "default": "yes",
                      "trueValue": "yes",
                      "falseValue": "no"
                    },
                    {
                      "type": "switch",
                      "title": "Allow zone drifting",
                      "description": "",
                      "key": "AllowZoneDrifting",
                      "default": "no",
                      "trueValue": "yes",
                      "falseValue": "no"
                    },
                    {
                      "type": "dropdown",
                      "title": "Automatic helpers",
                      "description": "",
                      "key": "AutomaticHelpers",
                      "default": "system",
                      "options": [
                        "yes",
                        "no",
                        "system"
                      ]
                    },
                    {
                      "type": "dropdown",
                      "title": "Log denied",
                      "description": "",
                      "key": "LogDenied",
                      "default": "off",
                      "options": [
                        "off",
                        "all",
                        "unicast",
                        "broadcast",
                        "multicast"
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "pageButton",
              "title": "Permanent Configurations",
              "description": "Edit user-defined firewalld XML files.",
              "items": [
                {
                  "type": "section",
                  "title": "Permanent XML Files",
